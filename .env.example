# AWS RDS MySQL Connection
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_NAME=rigguard
DB_USER=admin
DB_PASSWORD=your_password_here
DB_SSL=true

# App
NODE_ENV=production
JWT_SECRET=change_this_to_a_long_random_secret

# Frontend (build args)
VITE_API_URL=http://your-api-domain-or-ip:3001
VITE_PREDICTION_URL=http://your-api-domain-or-ip:8000
